<!-- Page Header -->
<div class="page-header">
  <h1>Travel Packages</h1>
  <p>Discover our amazing collection of travel packages</p>
</div>

<!-- Content -->
<div class="content-container">
  {{#if trips}}
    <div class="cards-grid">
      {{#each trips}}
      <div class="card">
        <div class="card-image">
          {{#if image}}
            <img src="/images/{{image}}.svg" alt="{{name}}" loading="lazy">
          {{else}}
            <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 3rem;">🏖️</div>
          {{/if}}
        </div>
        <div class="card-content">
          <span class="card-badge">{{code}}</span>
          <h3 class="card-title">{{name}}</h3>
          <p class="card-meta">🏨 {{resort}}</p>
          <p class="card-meta">📅 {{start}}</p>
          <p class="card-meta">🌙 {{length}} nights</p>
          <div class="card-price">
            ${{perPerson}}
            <span class="card-price-label">per person</span>
          </div>
          <a href="/travel/{{code}}" class="card-button">View Details</a>
        </div>
      </div>
      {{/each}}
    </div>
  {{else}}
    <div class="empty-state">
      <p>❌ No travel packages available at the moment.</p>
      <a href="/" class="btn" style="display: inline-block; padding: 10px 24px; background: var(--primary); color: white; border-radius: 8px;">Return Home</a>
    </div>
  {{/if}}
</div>