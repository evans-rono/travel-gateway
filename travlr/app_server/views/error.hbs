<div class="page-header" style="background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);">
  <h1>Oops! Something went wrong</h1>
  <p>{{message}}</p>
</div>

<div class="content-container">
  <div class="empty-state" style="padding: 80px 40px;">
    <p style="font-size: 4rem; margin-bottom: 20px;">⚠️</p>
